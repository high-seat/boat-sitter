# Copy to .dev.vars for local development (gitignored).
# .dev.vars overrides wrangler.json `vars` during `wrangler dev` / Vite, so local
# runs stay in development mode (dev console + /api/dev open) while deploys are
# production.
ENVIRONMENT=development
# Overrides wrangler.json so local/e2e sign-in works without email verification.
REQUIRE_EMAIL_VERIFICATION=false
ADMIN_TOKEN=dev-token
BETTER_AUTH_URL=http://127.0.0.1:5173
BETTER_AUTH_SECRET=dev-local-better-auth-secret-32chars
GOOGLE_CLIENT_ID=unused-local
GOOGLE_CLIENT_SECRET=unused-local

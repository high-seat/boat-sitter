{
  "name": "boatstead",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "start": "vite --open",
    "build": "tsgo -b && vite build",
    "cf-typegen": "wrangler types",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsgo -b",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "test": "jest",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "check": "pnpm typecheck && pnpm lint && pnpm fmt:check && pnpm test:unit && vite build && wrangler deploy --dry-run",
    "preview": "pnpm build && vite preview --open",
    "db:generate": "drizzle-kit generate",
    "db:seed:generate": "node --experimental-strip-types scripts/generate-seed-sql.ts",
    "db:verify": "python3 scripts/verify_sql.py",
    "verify:coords": "node --experimental-strip-types scripts/verify_coordinates.ts",
    "db:seed:places:generate": "node --experimental-strip-types scripts/generate-world-places-sql.ts",
    "db:seed:places:local": "wrangler d1 execute boat-sitter-db --local --file=./scripts/world-places.sql",
    "db:seed:places:remote": "wrangler d1 execute boat-sitter-db --remote --file=./scripts/world-places.sql",
    "db:migrate:local": "wrangler d1 migrations apply boat-sitter-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply boat-sitter-db --remote",
    "db:seed:local": "wrangler d1 execute boat-sitter-db --local --file=./scripts/seed.sql",
    "db:seed:remote": "wrangler d1 execute boat-sitter-db --remote --file=./scripts/seed.sql",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.0",
    "@ocodio/query-key-manager": "^0.1.2",
    "@radix-ui/react-popover": "^1.1.20",
    "@tanstack/react-query": "^5.101.2",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-list": "^2.4.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.12.31",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "react-leaflet": "^5.0.0",
    "react-phone-input-2": "^2.15.1",
    "react-router-dom": "^7.18.1",
    "react-social-login-buttons": "^4.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.3",
    "@types/country-list": "^2.1.4",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.0",
    "jest": "^30.4.2",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.3",
    "ts-jest": "^29.4.12",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.15.1"
}
